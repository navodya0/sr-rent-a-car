
RewriteEngine on
RewriteRule ^page/([0-9]+)$ /index.php?id=$1 [L]
RewriteCond %{HTTP_HOST} ^srilankarentacar\.com$ [OR]
RewriteCond %{HTTP_HOST} ^www\.srilankarentacar\.com$
#RewriteRule ^(.*)$ "https\:\/\/www\.srilankarentacar\.lk\/$1" [R=301,L]


<FilesMatch "\.(php)$">
    Allow from all
</FilesMatch>

RewriteEngine On
RewriteRule ^(assets|manager|connectors|core) - [L]
#RewriteRule ^index\.php$ - [L]
#RewriteCond %{REQUEST_FILENAME} !-f
#RewriteCond %{REQUEST_FILENAME} !-d
#RewriteRule ^(.*)$ index.php [QSA,L]


RewriteEngine On
RewriteBase /

# Remove .html extension from URLs
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)/$ /$1 [R=301,L]

# MODX-Friendly URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?q=$1 [L,QSA]

# Custom rewrite for static URLs (Example: Product page)
RewriteRule ^product/([0-9]+)$ product.php?id=$1 [L,QSA]

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php74” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
